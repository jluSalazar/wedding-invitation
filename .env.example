# ──────────────────────────────────────────────────────────────
#  Environment Variables — Wedding RSVP App
#  Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────

# MongoDB connection string (required)
# Local:  mongodb://localhost:27017/wedding
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/wedding?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@wedding.2nl3pyo.mongodb.net/?appName=wedding

# Admin panel token (required for /admin route)
# Example URL: /admin?token=<ADMIN_TOKEN>
ADMIN_TOKEN=change-me-admin-token
